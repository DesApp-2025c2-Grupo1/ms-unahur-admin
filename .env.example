# Variables de entorno para el Backend

# Puerto de la aplicación
PORT=3000

# Base de datos PostgreSQL
# Para desarrollo local con Docker Compose
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mediunahur_db?schema=public"

# Para producción en Dokploy (actualizar con tus credenciales)
# DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db?schema=public"

# Entorno
NODE_ENV=development
